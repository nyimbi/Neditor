{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "opener:default",
    "shell:allow-execute",
    "store:default",
    "window-state:default"
  ]
}
